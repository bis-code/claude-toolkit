FROM debian:12

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        bash \
        git \
        jq \
        curl \
        nodejs \
        npm && \
    rm -rf /var/lib/apt/lists/*

# Mock claude CLI so install.sh does not block waiting for a real binary
RUN printf '#!/bin/bash\necho "claude mock"\n' > /usr/local/bin/claude && \
    chmod +x /usr/local/bin/claude

COPY . /toolkit

WORKDIR /test-project

RUN git init && \
    git config user.email "test@test.com" && \
    git config user.name "Test"

RUN printf 'module test\ngo 1.21\n' > go.mod

ENTRYPOINT ["bash", "/toolkit/docker/test-entrypoint.sh"]
